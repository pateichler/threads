{
  "name": "@pateichler/threads",
  "version": "0.1.0",
  "description": "Markdown to static HTML compiler for personal threads",
  "files": ["dist"],
  "bin": {
    "threads": "dist/compile.js",
    "threads-pre": "dist/preprocess.js"
  },
  "scripts": {
    "build": "tsc",
    "compile": "tsc && node dist/compile.js",
    "clean": "tsc && node dist/preprocess.js clean",
    "sync": "tsc && node dist/preprocess.js sync"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "gray-matter": "^4.0.3",
    "marked": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
