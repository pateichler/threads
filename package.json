{
  "name": "threads",
  "version": "1.0.0",
  "description": "Markdown to static HTML compiler for personal threads",
  "scripts": {
    "build": "tsc",
    "compile": "tsc && node compile.js",
    "clean": "tsc && node preprocess.js clean",
    "sync": "tsc && node preprocess.js sync"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "gray-matter": "^4.0.3",
    "marked": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
